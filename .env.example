# SQL Server (worker-service + scripts)
# Copy to .env and adjust: cp .env.example .env

DB_SERVER=192.168.123.242
DB_PORT=1433
# DB_INSTANCE=SQL2022DEV
DB_NAME=ils
DB_USER=manh
DB_PASSWORD=manh

DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_POOL_MAX=20
DB_REQUEST_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=15000

# Worker throughput (docker-compose can override)
WORKER_PREFETCH=20
